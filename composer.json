{
    "name": "expense-management/system",
    "description": "Enterprise Expense Management System",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^3.0",
        "laravel/tinker": "^2.8",
        "tightenco/ziggy": "^1.0",
        "inertiajs/inertia-laravel": "^0.6",
        "predis/predis": "^2.2",
        "guzzlehttp/guzzle": "^7.8",
        "maatwebsite/excel": "^3.1",
        "barryvdh/laravel-dompdf": "^2.1",
        "sentry/sentry-laravel": "^3.8",
        "spatie/laravel-permission": "^6.3",
        "spatie/laravel-query-builder": "^5.2",
        "spatie/laravel-fractal": "^6.4",
        "firebase/php-jwt": "^6.8",
        "twilio/sdk": "^8.9",
        "sendgrid/sendgrid": "^7.11",
        "aws/aws-sdk-php": "^3.284",
        "league/flysystem-aws-s3-v3": "^3.23",
        "google/apiclient": "^2.61",
        "knj/google-maps-php": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "pestphp/pest": "^2.28",
        "pestphp/pest-plugin-laravel": "^2.2",
        "laravel/dusk": "^7.11",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
